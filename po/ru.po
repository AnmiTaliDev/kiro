#: data/kz.anmitali.kiro.desktop.in:5 data/kz.anmitali.kiro.appdata.xml:7
msgid "A modern and elegant terminal emulator"
msgstr "Современный и элегантный эмулятор терминала"

#: data/kz.anmitali.kiro.desktop.in:13
msgid "terminal;shell;prompt;command;commandline;cmd;"
