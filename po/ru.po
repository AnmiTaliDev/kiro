msgid "Copy on select functionality"
msgstr "Функция копирования при выделении"

#: data/kz.anmitali.kiro.appdata.xml:23
msgid "Configurable keyboard shortcuts"
msgstr "Настраиваемые горячие клавиши"

#: data/kz.anmitali.kiro.appdata.xml:24
msgid "Multiple cursor shapes and blinking options"
msgstr "Различные формы курсора и опции мигания"

#: data/kz.anmitali.kiro.appdata.xml:25
msgid "Scrollback buffer management"
msgstr "Управление буфером истории"

#: data/kz.anmitali.kiro.appdata.xml:33
msgid "Main terminal interface"
msgstr "Основной интерфейс терминала"

